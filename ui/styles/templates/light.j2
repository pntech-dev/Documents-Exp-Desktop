QWidget {
	background-color: {{ neutral.neutral_0 }};
}


/* Logo */
LogoLabel {
	background-repeat: no-repeat;
    background-position: left;
}


/* QLabel */
QLabel {
	color: {{ neutral.neutral_900 }};
}


/* Info label */
InfoLabel {
	color: {{ neutral.neutral_700 }};
}


/* Buttons */
QPushButton {
	border-radius: 8px;
}

/* Theme button */
ThemeButton {
	border: 0px;
	background-repeat: no-repeat;
    background-position: left;
}

ThemeButton:hover {
	background-color: {{ neutral.neutral_0 }};
}

ThemeButton:pressed {
	background-color: {{ neutral.neutral_0 }};
}

ThemeButton:disabled {
	background-color: {{ neutral.neutral_0 }};
}

/* Primary button */
PrimaryButton {
	border: 0px;
	color: {{ neutral.neutral_0 }};
	background-color: {{ accent.accent_500 }};
	font-weight: bold;
	font-size: 12pt;
	padding: 0px 16px;
}

PrimaryButton:hover {
	background-color: {{ accent.accent_600 }};
}

PrimaryButton:pressed {
	background-color: {{ accent.accent_400 }};
}

PrimaryButton:disabled {
	background-color: {{ neutral.neutral_50 }};
}

/* Secondary button */
SecondaryButton {
	border: 1px solid {{ neutral.neutral_100 }};
	color: {{ neutral.neutral_600 }};
	background-color: {{ neutral.neutral_50 }};
	padding: 0px 16px;
}

SecondaryButton:hover {
	border: 1px solid {{ neutral.neutral_200 }};
	color: {{ neutral.neutral_700 }};
	background-color: {{ neutral.neutral_150 }};
}

SecondaryButton:pressed {
	border: 1px solid {{ neutral.neutral_300 }};
	color: {{ neutral.neutral_800 }};
	background-color: {{ neutral.neutral_200 }};
}

SecondaryButton:disabled {
	border: 1px solid {{ neutral.neutral_50 }};
	color: {{ neutral.neutral_50 }};
	background-color: {{ neutral.neutral_0 }};
}

/* Tertiary button */
TertiaryButton {
	border: 1px solid {{ neutral.neutral_50 }};
	color: {{ neutral.neutral_700 }};
	padding: 0px 16px;
}

TertiaryButton:hover {
	border: 1px solid {{ neutral.neutral_100 }};
	color: {{ neutral.neutral_700 }};
	background-color: {{ neutral.neutral_50 }};
}

TertiaryButton:pressed {
	border: 1px solid {{ neutral.neutral_150 }};
	color: {{ neutral.neutral_800 }};
	background-color: {{ neutral.neutral_100 }};
}

TertiaryButton:disabled {
	border: 1px solid {{ neutral.neutral_50 }};
	color: {{ neutral.neutral_50 }};
	background-color: {{ neutral.neutral_0 }};
}

/* Text button */
TextButton {
	color: {{ accent.accent_500 }};
}

TextButton:hover {
	color: {{ accent.accent_600 }};
}

TextButton:pressed {
	color: {{ accent.accent_400 }};
}

TextButton:disabled {
	color: {{ accent.accent_100 }};
}


/* CheckBox */
QCheckBox {
	spacing: 8px;
	color: {{ neutral.neutral_600 }};
}

QCheckBox:hover {
	color: {{ neutral.neutral_800 }};
}

QCheckBox:disabled {
	color: {{ neutral.neutral_50 }};
}

QCheckBox:checked {
	color: {{ neutral.neutral_900 }};
}

QCheckBox:checked:disabled {
	color: {{ neutral.neutral_100 }};
}

QCheckBox::indicator {
	width: 18px;
	height: 18px;
	border: 1px solid {{ neutral.neutral_500 }};
	border-radius: 4px;
	background-color: {{ neutral.neutral_0 }};
}

QCheckBox::indicator:hover {
	border: 1px solid {{ neutral.neutral_700 }};
}

QCheckBox::indicator:disabled {
	border: 1px solid {{ neutral.neutral_50 }};
}

QCheckBox::indicator:checked {
	width: 20px;
	height: 20px;
	border: 0px;
	background-color: {{ accent.accent_500 }};
	image: url(:/icons/light/check/light/default.svg);
}

QCheckBox::indicator:checked:hover {
	background-color: {{ accent.accent_600 }};
}

QCheckBox::indicator:checked:disabled {
	background-color: {{ accent.accent_100 }};
}


/* LineEdits */
QLineEdit {
	border-radius: 8px;
	border: 1px solid {{ neutral.neutral_100 }};
	background-color: {{ neutral.neutral_0 }};
	color: {{ neutral.neutral_500 }};
	padding: 0px 16px;
}

QLineEdit:hover {
	border: 1px solid {{ neutral.neutral_150 }};
	color: {{ neutral.neutral_700 }};
}

QLineEdit:focus {
	border: 1px solid {{ accent.accent_500 }};
	color: {{ neutral.neutral_900 }};
}

QLineEdit:disabled {
	border: 1px solid {{ neutral.neutral_50 }};
	color: {{ neutral.neutral_900 }};
}


/* Notifications */
#Notification {
	background-color: transparent;
    border: none;
}

#notification_container {
	background-color: {{ neutral.neutral_0 }};
	border-radius: 8px;
    border: 1px solid {{ neutral.neutral_100 }};
	padding: 1px;
}

#Notification #label {
	color: {{ neutral.neutral_900 }};
}

#Notification #description {
	color: {{ neutral.neutral_700 }};
}

#Notification #notify_type_line_frame {
    border-radius: 7px;
	margin: 1px 0px 1px 1px;
}

#Notification #close_pushButton {
	background-image: url(:/icons/light/close/light/default.svg);
	background-repeat: no-repeat;
    background-position: center;
	border-radius: 0px;
}

#Notification #close_pushButton:hover {
	background-image: url(:/icons/light/close/light/hover.svg);
}

#Notification #close_pushButton:pressed {
	background-image: url(:/icons/light/close/light/clicked.svg);
}

#Notification #close_pushButton:disabled {
	background-image: url(:/icons/light/close/light/disabled.svg);
}

/* Success */
#Notification[notificationType="success"] #notify_type_line_frame {
	background-color: {{ semantic.success.success_500 }};
}

/* Info */
#Notification[notificationType="info"] #notify_type_line_frame {
	background-color: {{ semantic.info.info_500 }};
}

/* Warning */
#Notification[notificationType="warning"] #notify_type_line_frame {
	background-color: {{ semantic.warning.warning_500 }};
}

/* Error */
#Notification[notificationType="error"] #notify_type_line_frame {
	background-color: {{ semantic.error.error_500 }};
}


/* Email Confirm Window */
QFrame#emailConfirmContainer {
    border-radius: 8px;
    background-color: {{ neutral.neutral_0 }};
}



/* MAIN APPLICATION */

/* Sidebar */
SidebarBlock {
	background-color: {{ neutral.neutral_0 }};
	selection-background-color: {{ accent.accent_500 }};

	qproperty-badgeBackgroundColor: transparent;
	qproperty-badgeTextColor: {{ neutral.neutral_300 }};
	qproperty-badgeBackgroundSelectedColor: {{ neutral.neutral_0 }};
	qproperty-badgeTextSelectedColor: {{ neutral.neutral_900 }};
	qproperty-badgeBackgroundHoverColor: {{ neutral.neutral_150 }};
	qproperty-badgeTextHoverColor: {{ neutral.neutral_800 }};
	
	qproperty-disabledTextColor: {{ neutral.neutral_100 }};
	qproperty-hoverBackgroundColor: {{ neutral.neutral_50 }};

	qproperty-groupTextColor: {{ neutral.neutral_900 }};
	qproperty-groupTextHoverColor: {{ neutral.neutral_600 }};

	qproperty-itemTextColor: {{ neutral.neutral_600 }};
	qproperty-itemTextHoverColor: {{ neutral.neutral_800 }};
	qproperty-itemTextSelectedColor: {{ neutral.neutral_0 }};

	qproperty-groupIcon: url(:/icons/light/arrow/light/default.svg);
	qproperty-groupIconHover: url(:/icons/light/arrow/light/hover.svg);
}

QFrame#sidebar_frame {
	border-right: 1px solid {{ neutral.neutral_100 }};
}

/* Logo */
QFrame#logo_frame {
	border-bottom: 1px solid {{ neutral.neutral_100 }};
}

/* Profile */
QFrame#profile_frame {
	border-top: 1px solid {{ neutral.neutral_100 }};
}


/* Navbar */
QFrame#navbar_frame {
	border-bottom: 1px solid {{ neutral.neutral_100 }};
}


/* Content */
QFrame#main_content_frame {
	background-color: {{ neutral.neutral_50 }};
}