QWidget {
	background-color: {{ neutral.neutral_0 }};
}


/* Logo */
QLabel#logo_lable {
	background-image: url(:/light/logo_light.svg);
	background-repeat: no-repeat;
    background-position: left;
}


/* QLabel */
QLabel {
	color: {{ neutral.neutral_900 }};
}


/* Buttons */
QPushButton {
	border-radius: 8px;
}

/* Theme button */
QPushButton#theme_button {
	border: 0px;
	background-image: url(:/icons/light/theme/light/default.svg);
	background-repeat: no-repeat;
    background-position: left;
}

QPushButton#theme_button:hover {
	background-image: url(:/icons/light/theme/light/hover.svg);
	background-color: {{ neutral.neutral_100 }};
}

QPushButton#theme_button:pressed {
	background-image: url(:/icons/light/theme/light/clicked.svg);
	background-color: {{ neutral.neutral_100 }};
}

QPushButton#theme_button:disabled {
	background-image: url(:/icons/light/theme/light/disabled.svg);
	background-color: {{ neutral.neutral_100 }};
}

/* Primary button */
QPushButton#login_pushButton {
	border: 0px;
	color: {{ neutral.neutral_0 }};
	background-color: {{ accent.accent_500 }};
}

QPushButton#login_pushButton:hover {
	background-color: {{ accent.accent_400 }};
}

QPushButton#login_pushButton:pressed {
	background-color: {{ accent.accent_600 }};
}

QPushButton#login_pushButton:disabled {
	background-color: {{ neutral.neutral_200 }};
	color: {{ neutral.neutral_300 }};
}

