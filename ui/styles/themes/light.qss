QWidget {
	background-color: #FFFFFF;
}


/* Logo */
QLabel#logo_lable {
	background-image: url(:/light/logo_light.svg);
	background-repeat: no-repeat;
    background-position: left;
}


/* QLabel */
QLabel {
	color: #1A1A1A;
}


/* Buttons */
QPushButton {
	border-radius: 8px;
}

/* Theme button */
QPushButton#theme_button {
	border: 0px;
	background-image: url(:/theme/light/theme/light/default.svg);
	background-repeat: no-repeat;
    background-position: left;
}

QPushButton#theme_button:hover {
	background-image: url(:/theme/light/theme/light/hover.svg);
	background-color: #FFFFFF;
}

QPushButton#theme_button:pressed {
	background-image: url(:/theme/light/theme/light/clicked.svg);
	background-color: #FFFFFF;
}

QPushButton#theme_button:disabled {
	background-image: url(:/theme/light/theme/light/disabled.svg);
	background-color: #FFFFFF;
}

/* Primary button */
QPushButton#login_pushButton {
	border: 0px;
	color: #FFFFFF;
	background-color: #CC3333;
}

QPushButton#login_pushButton:hover {
	background-color: #A32929;
}

QPushButton#login_pushButton:pressed {
	background-color: #D65C5C;
}

QPushButton#login_pushButton:disabled {
	background-color: #F2F2F2;
}

