QWidget {
	background-color: #262626;
}


/* Logo */
QLabel#logo_lable {
	background-image: url(:/dark/logo_dark.svg);
	background-repeat: no-repeat;
    background-position: left;
}


/* QLabel */
QLabel {
	color: #E6E6E6;
}


/* Buttons */
QPushButton {
	border-radius: 8px;
}

/* Theme button */
QPushButton#theme_button {
	border: 0px;
	background-image: url(:/theme/dark/theme/dark/default.svg);
	background-repeat: no-repeat;
    background-position: left;
}

QPushButton#theme_button:hover {
	background-image: url(:/theme/dark/theme/dark/hover.svg);
	background-color: #262626;
}

QPushButton#theme_button:pressed {
	background-image: url(:/theme/dark/theme/dark/clicked.svg);
	background-color: #262626;
}

QPushButton#theme_button:disabled {
	background-image: url(:/theme/dark/theme/dark/disabled.svg);
	background-color: #262626;
}

/* Primary button */
QPushButton#login_pushButton {
	border: 0px;
	color: #E6E6E6;
	background-color: #C43A3A;
}

QPushButton#login_pushButton:hover {
	background-color: #D65A5A;
}

QPushButton#login_pushButton:pressed {
	background-color: #852222;
}

QPushButton#login_pushButton:disabled {
	background-color: #333333;
	color: #4D4D4D;
}

